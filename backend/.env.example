# Copy to .env (or use docker-compose) and fill in.

# Database
DATABASE_URL=postgresql+psycopg2://lexhaiti:lexhaiti@localhost:5432/lexhaiti

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO in dev, B2 in prod — both S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=lexhaiti-dev
S3_REGION=us-east-1

# API
API_PREFIX=/api
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Editorial / observability (later)
# SENTRY_DSN=
# LOG_LEVEL=INFO
